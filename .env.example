# ─── SERVER ───────────────────────────────────────────────────────────────────
DOMAIN=phoenix-finance.tuo-dominio.com

# ─── LLM PROVIDERS ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── LITELLM ──────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-litellm-cambia-questa-chiave
LITELLM_BASE_URL=http://litellm:4000/v1

# ─── QDRANT ───────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── POSTGRESQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=phoenix_finance
POSTGRES_USER=phoenix
POSTGRES_PASSWORD=cambia-questa-password-postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── GOOGLE WORKSPACE ─────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=/run/secrets/google_sa
GOOGLE_DRIVE_FOLDER_ID=

# ─── CONCIERGE / API GATEWAY ──────────────────────────────────────────────────
CONCIERGE_PORT=8000
AGENT_SECRET_TOKEN=cambia-questo-token-segreto
CONCIERGE_INTERNAL_URL=http://concierge:8000

# ─── SERVIZI — porte interne ──────────────────────────────────────────────────
AGENT_FINANCE_PORT=8010
ANALYTICS_PORT=8040
ANALYTICS_URL=http://analytics:8040
ANALYTICS_AUTH_TOKEN=cambia-questo-token-dashboard

# ─── INTEGRAZIONI FINANZIARIE ─────────────────────────────────────────────────
# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Banche / Open Banking
OPENBANKING_API_KEY=
OPENBANKING_BASE_URL=

# Notifiche
BREVO_API_KEY=xkeysib-...

# Tavily (ricerca web)
TAVILY_API_KEY=tvly-...
